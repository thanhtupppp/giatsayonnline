rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Đọc user doc để lấy maCuaHang — dùng get() vì chưa có custom claims
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userStoreId() {
      return userDoc().data.maCuaHang;
    }

    function userRole() {
      return userDoc().data.vaiTro;
    }

    function isAdmin() {
      return userRole() in ["ADMIN", "SUPER_ADMIN"];
    }

    function isSameStore(storeId) {
      return isSignedIn() && userStoreId() == storeId;
    }

    // Users: đọc profile bằng uid trực tiếp
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn();
    }

    // Store document
    match /cuaHang/{storeId} {
      allow read: if isSameStore(storeId);
      allow write: if isAdmin() && isSameStore(storeId);
    }

    // Orders — tách get/list để hỗ trợ lookup đơn cũ (doc không tồn tại ở ID mới)
    match /donHang/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Customers — tách get/list tương tự
    match /khachHang/{customerId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Services
    match /dichVu/{serviceId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Store config
    match /cauHinhCuaHang/{storeId} {
      allow read: if isSameStore(storeId);
      allow write: if isAdmin() && isSameStore(storeId);
    }

    // Transactions
    match /giaoDich/{transactionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Reports
    match /baoCao/{reportId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Print Jobs
    match /print_jobs/{jobId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Audit logs
    match /auditLog/{logId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if false;
    }

    // Inventory
    match /tonKho/{inventoryId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Coupons
    match /phieuGiamGia/{couponId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Notifications
    match /thongBao/{notifyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }
  }
}
