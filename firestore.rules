rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ✅ Dùng Custom Claims — không tốn reads
    function userStoreId() {
      return request.auth.token.maCuaHang;
    }

    function userRole() {
      return request.auth.token.vaiTro;
    }

    function isAdmin() {
      return userRole() in ["ADMIN", "SUPER_ADMIN"];
    }

    function isSameStore(storeId) {
      return isSignedIn() && userStoreId() == storeId;
    }

    // Users: đọc profile bằng uid trực tiếp — không dùng claims
    // vì đây chính là bước lấy thông tin để set claims
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn();
    }

    // Store document
    match /cuaHang/{storeId} {
      allow read: if isSameStore(storeId);
      allow write: if isAdmin() && isSameStore(storeId);
    }

    // Orders
    match /donHang/{orderId} {
      allow read: if isSignedIn()
        && (
          !resource.data.keys().hasAny(['maCuaHang'])
          || isSameStore(resource.data.maCuaHang)
        );

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Customers
    match /khachHang/{customerId} {
      allow read: if isSignedIn()
        && (
          !resource.data.keys().hasAny(['maCuaHang'])
          || isSameStore(resource.data.maCuaHang)
        );

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);
    }

    // Services
    match /dichVu/{serviceId} {
      allow read: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isAdmin()
        && isSameStore(resource.data.maCuaHang);
    }

    // Store config
    match /cauHinhCuaHang/{storeId} {
      allow read: if isSameStore(storeId);
      allow write: if isAdmin() && isSameStore(storeId);
    }

    // Transactions
    match /giaoDich/{transactionId} {
      allow read: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isAdmin()
        && isSameStore(resource.data.maCuaHang);
    }

    // Reports
    match /baoCao/{reportId} {
      allow read: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isAdmin()
        && isSameStore(resource.data.maCuaHang);
    }

    // Print Jobs
    match /print_jobs/{jobId} {
      allow read, write: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
    }

    // Audit logs
    match /auditLog/{logId} {
      allow read: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if false;
    }

    // Inventory
    match /tonKho/{inventoryId} {
      allow read: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isAdmin()
        && isSameStore(resource.data.maCuaHang);
    }

    // Coupons
    match /phieuGiamGia/{couponId} {
      allow read: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);

      allow update, delete: if isAdmin()
        && isSameStore(resource.data.maCuaHang);
    }

    // Notifications
    match /thongBao/{notifyId} {
      allow read, write: if isSignedIn()
        && isSameStore(resource.data.maCuaHang);

      allow create: if isSignedIn()
        && isSameStore(request.resource.data.maCuaHang);
    }
  }
}
