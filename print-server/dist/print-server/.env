# MỖI MÁY IN = MỘT CỬA HÀNG (không in chéo)
# Chọn cửa hàng 1 lần đầu tiên bằng 1 trong 3 cách:
# 1) MA_CUA_HANG=...
# 2) node server.js --store=<id>
# 3) INTERACTIVE_STORE_SELECT=true để chọn trên terminal
# Sau khi chọn, server sẽ lưu local và lần sau tự dùng lại.

MA_CUA_HANG=
INTERACTIVE_STORE_SELECT=true
LOCK_STORE_SELECTION=true

# Collection cấu hình
PRINT_COLLECTION=print_jobs
ORDER_COLLECTION=donHang
STORE_COLLECTION=cuaHang
PRINT_LOG_COLLECTION=print_job_logs

# Máy in / mode in
# pdf | notepad
# Khuyến nghị 'pdf' để có barcode + ổn định qua driver Windows
PRINT_MODE=pdf
PRINTER_NAME=

# In nền, không hiện popup
PRINT_SILENT=true
PRINT_DIALOG=false

# Khổ giấy
PAPER_SIZE_MM=80

# Retry & startup filter
PRINT_MAX_RETRY=2
PRINT_RETRY_DELAY_MS=1500
SKIP_OLD_JOB_MS=5000

# Template hóa đơn (fallback nếu không lấy được từ DB)
STORE_NAME=Giat Say
STORE_ADDRESS=
STORE_PHONE=
RECEIPT_FOOTER=Cam on quy khach!\nVui long giu phieu nay de nhan do
